---
// Bande sombre « terminal » — point de drame + crédibilité data.
const stats = [
  { k: 'DAAF', l: 'source officielle unique' },
  { k: '0', l: 'prix inventé' },
  { k: 'quotidien', l: 'relevés historisés' },
  { k: 'etalab 2.0', l: 'données ouvertes' },
]
---
<section class="term" data-reveal>
  <div class="container">
    <p class="head num">// BAZAR PÉI — DATA<span class="cursor">▌</span></p>
    <div class="grid">
      {stats.map((s) => (
        <div class="stat">
          <span class="k num">{s.k}</span>
          <span class="l">{s.l}</span>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .term { background: var(--ink); color: var(--cream); padding: var(--sp-xxl) 0; }
  .head { color: var(--leaf); font-size: 13px; letter-spacing: 1px; margin-bottom: var(--sp-xl); }
  .cursor { display: inline-block; margin-left: 2px; animation: blink 1.1s step-end infinite; }
  @keyframes blink { 50% { opacity: 0; } }
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: var(--sp-xl); }
  .stat { display: flex; flex-direction: column; gap: 4px; border-left: 2px dotted rgba(255, 248, 242, 0.25); padding-left: var(--sp-md); }
  .k { font-family: var(--font-mono); font-weight: 600; font-size: clamp(22px, 4vw, 30px); color: var(--mango); }
  .l { font-size: 13px; color: rgba(255, 248, 242, 0.7); }
</style>
