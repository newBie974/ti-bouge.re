---
interface Props { id: string; title?: string; bg?: 'cream' | 'low' | 'paper' }
const { id, title, bg = 'cream' } = Astro.props
---
<section id={id} class={`bg-${bg}`}>
  <div class="container">
    {title && <h2>{title}</h2>}
    <slot />
  </div>
</section>
<style>
  section { padding: var(--sp-huge) 0; }
  .bg-cream { background: var(--cream); }
  .bg-low { background: var(--cream-low); }
  .bg-paper { background: var(--paper); }
  h2 { font-size: clamp(24px, 4vw, 32px); margin-bottom: var(--sp-lg); }
</style>
