---
// Démo INTERACTIVE : 3 options en haut → 3 scénarios DIFFÉRENTS (message, panier, recette).
// Au clic : message utilisateur, Ti Boug « réfléchit » (étapes avec faux chargement spinner → ✓),
// puis panier + recette propres au scénario. Rejouable. Sans JS : le 1er scénario s'affiche.
const SCENARIOS = [
  {
    chip: 'Rougail saucisse 🌶️',
    q: 'Fé moin in rougail saucisse pou 4 🌶️',
    line: 'Voilà ton panié pou 4 personnes :',
    basket: [
      { n: 'Saucisses fumées', p: '4,90 €', d: false },
      { n: 'Tomates (500 g)', p: '1,20 €', d: true },
      { n: 'Oignons', p: '0,60 €', d: false },
      { n: 'Ail · gingembre · piment', p: '0,80 €', d: false },
    ],
    total: '≈ 7,50 € · 1,90 €/pers',
    title: 'Rougail saucisse',
    steps: [
      'Fé bouï les saucisses 10 min, koup an rondèl.',
      "Roussi l'oignon, ajout tomate, ail, gingembre, piment.",
      'Mélanz les saucisses, kui 15 min. Ansanm èk du riz é grin. 💚',
    ],
  },
  {
    chip: 'Plat pas cher ce soir 🍛',
    q: 'In plat pa shé pou ce soir, kosa ou propoz ? 🍛',
    line: 'Pou pa shé ce soir, in bon cari poulet :',
    basket: [
      { n: 'Cuisses de poulet', p: '3,90 €', d: true },
      { n: 'Tomates (500 g)', p: '1,20 €', d: true },
      { n: 'Oignons', p: '0,60 €', d: false },
      { n: 'Curcuma · ail · thym', p: '0,90 €', d: false },
    ],
    total: '≈ 6,60 € · 1,65 €/pers',
    title: 'Cari poulet',
    steps: [
      "Roussi l'oignon avèk le curcuma.",
      'Ajout le poulet, fé dorer 5 min.',
      "Tomate, ail, thym, in vèr d'dlo, kui 25 min. Ansanm èk du riz. 💚",
    ],
  },
  {
    chip: 'Kosa lé bon marché ? 💸',
    q: 'Kosa lé bon marché ojordi ? 💸',
    line: 'Lé bons plans du jour — in achards avèk :',
    basket: [
      { n: 'Chou de Chine', p: '0,90 €', d: true },
      { n: 'Carottes', p: '1,00 €', d: false },
      { n: 'Chouchou', p: '0,80 €', d: true },
      { n: 'Citron · gingembre', p: '0,70 €', d: false },
    ],
    total: '≈ 3,40 € · trè bon marché',
    title: 'Achards légumes',
    steps: [
      'Émince fin les légumes, blanchi 2 min.',
      'Fé revenir avèk curcuma, ail, gingembre, piman.',
      "Ajout citron, sèl, l'huile. Lèss mariner. 💚",
    ],
  },
]
const s0 = SCENARIOS[0]
---
<div class="chat" id="chatdemo">
  <div class="chat-head">
    <img class="chat-av" src="/avatar.png" alt="" width="40" height="40" />
    <div>
      <p class="chat-name">Ti Boug</p>
      <p class="chat-sub num"><span class="dot"></span> assistant marché · en ligne</p>
    </div>
  </div>

  <div class="quick" id="chatquick">
    {SCENARIOS.map((s, i) => <button class="qr" type="button" data-idx={i}>{s.chip}</button>)}
  </div>

  <div class="msgs">
    <div class="bubble user step" data-step="user">{s0.q}</div>

    <div class="tool step" data-step="t1">
      <span class="ticon">🔎</span><span class="tlabel">Je regarde les prix du jour</span>
      <span class="spin" aria-hidden="true"></span><span class="tcheck">✓</span>
    </div>
    <div class="tool step" data-step="t2">
      <span class="ticon">🧺</span><span class="tlabel">Je compose ton panier</span>
      <span class="spin" aria-hidden="true"></span><span class="tcheck">✓</span>
    </div>

    <div class="bubble bot step" data-step="basket">
      <span class="basketline">{s0.line}</span>
      <div class="card">
        <ul class="basket-ul">
          {s0.basket.map((b) => (
            <li class="row">
              <span class="bn">{b.n}</span><span class="lead"></span>
              <span class={`bp num ${b.d ? 'price-down' : ''}`}>{b.p}{b.d ? ' ▾' : ''}</span>
            </li>
          ))}
        </ul>
        <div class="row total basket-total"><span class="bn">Total estimé</span><span class="lead"></span><span class="bp num">{s0.total}</span></div>
      </div>
    </div>

    <div class="tool step" data-step="t3">
      <span class="ticon">📖</span><span class="tlabel">Je trouve la recette</span>
      <span class="spin" aria-hidden="true"></span><span class="tcheck">✓</span>
    </div>

    <div class="bubble bot step" data-step="recipe">
      <strong class="recipe-title">{s0.title}</strong>
      <span class="steps recipe-steps" set:html={s0.steps.map((st, i) => `${i + 1}. ${st}`).join('<br />')}></span>
    </div>

    <div class="typing" aria-hidden="true"><span></span><span></span><span></span></div>
  </div>
</div>

<style>
  .chat { width: 100%; max-width: 440px; background: var(--paper); border: 1px solid var(--ink-line); border-radius: var(--radius-lg); box-shadow: 0 6px 24px rgba(30, 27, 22, 0.08); overflow: hidden; }
  .chat-head { display: flex; align-items: center; gap: var(--sp-sm); padding: var(--sp-md) var(--sp-lg); border-bottom: 1px solid var(--ink-line); }
  .chat-av { width: 40px; height: 40px; border-radius: var(--radius-pill); background: var(--cream-low); object-fit: contain; flex: none; }
  .chat-name { font-family: var(--font-display); font-weight: 800; font-size: 16px; }
  .chat-sub { font-size: 11px; color: var(--ink-soft); }
  .dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: var(--leaf); margin-right: 4px; }

  .quick { display: flex; flex-wrap: wrap; gap: var(--sp-sm); padding: var(--sp-md); border-bottom: 1px solid var(--ink-line); background: var(--cream-low); }
  .qr { font: inherit; font-size: 13px; font-weight: 600; color: var(--mango-deep); background: var(--paper); border: 1px solid var(--ink-line); border-radius: var(--radius-pill); padding: 6px var(--sp-md); cursor: pointer; transition: transform 0.12s ease, background 0.12s ease, color 0.12s ease; }
  .qr:hover { transform: translateY(-1px); }
  .qr.active { background: var(--mango); color: var(--ink); border-color: var(--mango); }

  .msgs { display: flex; flex-direction: column; gap: var(--sp-sm); padding: var(--sp-lg); min-height: 150px; }
  .bubble { max-width: 88%; padding: var(--sp-sm) var(--sp-md); border-radius: 16px; font-size: 14px; line-height: 1.5; }
  .user { align-self: flex-end; background: var(--mango); color: var(--ink); font-weight: 600; border-bottom-right-radius: 4px; }
  .bot { align-self: flex-start; background: var(--cream-low); border: 1px solid var(--ink-line); border-bottom-left-radius: 4px; }
  .steps { display: block; margin-top: var(--sp-sm); color: var(--ink-soft); }

  .tool { align-self: flex-start; max-width: 94%; display: flex; align-items: center; gap: var(--sp-sm); font-size: 13px; color: var(--ink-soft); background: var(--cream-low); border: 1px dashed var(--ink-line); border-radius: var(--radius-pill); padding: 6px 12px; }
  .ticon { flex: none; }
  .tlabel { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .tcheck { margin-left: auto; color: var(--leaf); font-weight: 700; flex: none; }
  .spin { margin-left: auto; flex: none; width: 13px; height: 13px; border-radius: 50%; border: 2px solid var(--ink-line); border-top-color: var(--mango-deep); animation: spin 0.7s linear infinite; display: none; }

  .card { margin-top: var(--sp-sm); background: var(--paper); border: 1px solid var(--ink-line); border-radius: var(--radius-md); padding: var(--sp-sm) var(--sp-md); }
  .card ul { list-style: none; }
  .row { display: flex; align-items: baseline; gap: var(--sp-sm); padding: 3px 0; font-size: 13px; }
  .bn { white-space: nowrap; flex: 0 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; }
  .lead { flex: 1; border-bottom: 2px dotted var(--ink-line); transform: translateY(-3px); }
  .bp { white-space: nowrap; font-weight: 600; flex: none; }
  .total { border-top: 1px solid var(--ink-line); margin-top: 4px; padding-top: var(--sp-sm); }
  .total .bn { font-weight: 700; }

  .typing { align-self: flex-start; display: none; gap: 4px; background: var(--cream-low); border: 1px solid var(--ink-line); border-radius: 16px; padding: 10px 12px; }
  .typing span { width: 6px; height: 6px; border-radius: 50%; background: var(--ink-soft); animation: blink 1s infinite; }
  .typing span:nth-child(2) { animation-delay: 0.15s; }
  .typing span:nth-child(3) { animation-delay: 0.3s; }

  .chat.is-interactive .step:not(.show) { display: none; }
  .chat.is-interactive .step.show { animation: msgIn 0.3s ease; }
  .chat.is-interactive .typing.show { display: flex; }
  .tool.done .spin { display: none; }
  .chat.is-interactive .tool.show:not(.done) .tcheck { display: none; }
  .chat.is-interactive .tool.show:not(.done) .spin { display: block; }

  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes blink { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }
  @keyframes msgIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
</style>

<script define:vars={{ scenarios: SCENARIOS }}>
  const chat = document.getElementById('chatdemo')
  if (chat) {
    chat.classList.add('is-interactive')
    const msgs = chat.querySelector('.msgs')
    const typing = chat.querySelector('.typing')
    const chips = Array.from(chat.querySelectorAll('.qr'))
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const step = (id) => chat.querySelector(`[data-step="${id}"]`)
    const wait = (ms) => new Promise((r) => setTimeout(r, reduce ? Math.min(ms, 120) : ms))
    let token = 0

    function fill(s) {
      step('user').textContent = s.q
      chat.querySelector('.basketline').textContent = s.line
      chat.querySelector('.basket-ul').innerHTML = s.basket
        .map((b) => `<li class="row"><span class="bn">${b.n}</span><span class="lead"></span><span class="bp num ${b.d ? 'price-down' : ''}">${b.p}${b.d ? ' ▾' : ''}</span></li>`)
        .join('')
      chat.querySelector('.basket-total .bp').textContent = s.total
      chat.querySelector('.recipe-title').textContent = s.title
      chat.querySelector('.recipe-steps').innerHTML = s.steps.map((st, i) => `${i + 1}. ${st}`).join('<br>')
    }
    const reset = () => {
      ;['user', 't1', 't2', 'basket', 't3', 'recipe'].forEach((id) => step(id)?.classList.remove('show', 'done'))
      typing.classList.remove('show')
    }
    async function play(i, chip) {
      const my = ++token
      chips.forEach((c) => c.classList.toggle('active', c === chip))
      reset()
      fill(scenarios[i])
      step('user').classList.add('show'); await wait(450); if (my !== token) return
      step('t1').classList.add('show'); await wait(820); if (my !== token) return
      step('t1').classList.add('done'); await wait(220); if (my !== token) return
      step('t2').classList.add('show'); await wait(820); if (my !== token) return
      step('t2').classList.add('done'); await wait(220); if (my !== token) return
      msgs.appendChild(typing); typing.classList.add('show'); await wait(520); if (my !== token) return
      typing.classList.remove('show'); step('basket').classList.add('show'); await wait(560); if (my !== token) return
      step('t3').classList.add('show'); await wait(820); if (my !== token) return
      step('t3').classList.add('done'); await wait(220); if (my !== token) return
      msgs.appendChild(typing); typing.classList.add('show'); await wait(520); if (my !== token) return
      typing.classList.remove('show'); step('recipe').classList.add('show')
    }

    chips.forEach((c, i) => c.addEventListener('click', () => play(i, c)))
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) if (e.isIntersecting) { io.disconnect(); play(0, chips[0]) }
    }, { threshold: 0.5 })
    io.observe(chat)
  }
</script>
