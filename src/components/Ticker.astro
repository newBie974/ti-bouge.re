---
interface TickerItem { name: string; price: string; trend: 'up' | 'down' | 'flat' }
interface Props { items: TickerItem[] }
const { items } = Astro.props
const ARROW = { up: '▴', down: '▾', flat: '' }
// Un "groupe" répété assez large pour couvrir les écrans larges, puis dupliqué :
// l'animation translateX -50% replace le 2e groupe exactement sur le 1er → boucle sans couture.
const group = [...items, ...items, ...items]
const loop = [...group, ...group]
---
<div class="ticker" aria-hidden="true">
  <div class="track">
    {loop.map((it) => (
      <span class="item num">
        {it.name} <span class={`price-${it.trend}`}>{it.price} {ARROW[it.trend]}</span>
      </span>
    ))}
  </div>
</div>
<style>
  .ticker { overflow: hidden; background: var(--cream-low); border-block: 1px solid var(--ink-line); }
  .track {
    display: flex; width: max-content; gap: var(--sp-xxl);
    white-space: nowrap; padding: var(--sp-md) 0;
    animation: scroll 60s linear infinite;
  }
  .item { font-size: 14px; color: var(--ink-soft); }
  .price-flat { color: var(--ink-soft); }
  @keyframes scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) {
    .track { animation: none; width: auto; flex-wrap: wrap; white-space: normal; }
  }
</style>
