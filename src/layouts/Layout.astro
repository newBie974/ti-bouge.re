---
import '../styles/tokens.css'
import '../styles/global.css'
import { SITE } from '../config'
interface Props { title: string; description: string }
const { title, description } = Astro.props
const canonical = new URL(Astro.url.pathname, SITE.domain).href
const ogImage = `${SITE.domain}/og.jpg`

// JSON-LD — aide le SEO ET les moteurs génératifs (LLM) à comprendre l'entité.
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'MobileApplication',
    name: 'Ti Boug — Bazar Péi',
    applicationCategory: 'ShoppingApplication',
    operatingSystem: 'iOS',
    description:
      "Application mobile qui suit les prix des fruits & légumes à La Réunion (tendance, saisonnalité, marchés forains et grandes surfaces) à partir des mercuriales publiques de la DAAF Réunion, et compose un panier au meilleur prix avec un assistant IA.",
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
    url: SITE.domain,
    image: ogImage,
    inLanguage: 'fr-FR',
    areaServed: { '@type': 'Place', name: 'La Réunion' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Ti Boug — Bazar Péi',
    url: SITE.domain,
    logo: `${SITE.domain}/favicon.png`,
    areaServed: { '@type': 'Place', name: 'La Réunion' },
  },
]
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" />
    <meta name="theme-color" content="#FFF8F2" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="geo.region" content="RE" />
    <meta name="geo.placename" content="La Réunion" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Ti Boug — Bazar Péi" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Ti Boug — prix des fruits & légumes à La Réunion" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <script>
      // Révèle les éléments [data-reveal] à l'entrée dans le viewport.
      const els = document.querySelectorAll('[data-reveal]')
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in')
              io.unobserve(e.target)
            }
          }
        },
        { rootMargin: '0px 0px -10% 0px' }
      )
      els.forEach((el) => io.observe(el))
    </script>
  </body>
</html>
